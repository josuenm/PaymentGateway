  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "customer-route": {
        "ClusterId": "customer-cluster",
        "AuthorizationPolicy": "ValidateToken",
        "Match": {
          "Path": "/api/v1/customers/{**catch-all}"
        }
      },
      "customer-internal-route": {
        "ClusterId": "customer-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/customers/internal/{**catch-all}"
        }
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "ValidateToken",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}"
        }
      },
      "catalog-internal-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/prices/internal/{**catch-all}"
        }
      },
      "billing-route": {
        "ClusterId": "billing-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/billing/{**catch-all}"
        }
      },
      "paymentlink-internal-route": {
        "ClusterId": "paymentlink-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/v1/paymentlinks/internal/{**catch-all}"
        }
      },
      "paymentlink-route": {
        "ClusterId": "paymentlink-cluster",
        "AuthorizationPolicy": "ValidateToken",
        "Order": 2,
        "Match": {
          "Path": "/api/v1/paymentlinks/{**catch-all}"
        }
      }, 
      "checkout-route": {
        "ClusterId": "checkout-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/checkouts/{**catch-all}"
        }
      }, 
      "payment-internal-route": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/payments/internal/{**catch-all}"
        }
      }
    }, 
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "local": { "Address": "http://localhost:5002" }
        }
      },
      "customer-cluster": {
        "Destinations": {
          "local": { "Address": "http://localhost:5003" }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "local": { "Address": "http://localhost:5004" }
        }
      }, 
      "billing-cluster": {
        "Destinations": {
          "local": { "Address": "http://localhost:5005" }
        }
      },
      "paymentlink-cluster": {
        "Destinations": {
          "local": { "Address": "http://localhost:5006" }
        }
      }, 
      "checkout-cluster": {
        "Destinations": {
          "local": { "Address": "http://localhost:5007" }
        }
      }, 
      "payment-cluster": {
        "Destinations": {
          "local": { "Address": "http://localhost:5008" }
        }
      }
    }
  }
}
